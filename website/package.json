{
  "name": "romanian-olympiad-solutions-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Bilingual (RO/EN) website for the Romanian Olympiad Solutions repository.",
  "scripts": {
    "index": "node scripts/build-catalog.mjs",
    "kilonova": "node scripts/build-catalog.mjs && node scripts/fetch-kilonova.mjs",
    "unmatched": "node scripts/build-catalog.mjs && node scripts/list-unmatched.mjs",
    "dev": "npm run index && astro dev",
    "start": "astro dev",
    "build": "npm run index && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.2.1",
    "astro": "^5.2.5",
    "astro-pagefind": "^1.8.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "pagefind": "^1.3.0",
    "typescript": "^5.7.3"
  }
}
